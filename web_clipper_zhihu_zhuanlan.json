{
  "schemaVersion": "0.1.0",
  "name": "知乎专栏",
  "behavior": "create",
  "noteContentFormat": "# {{title|replace:\" - 知乎\":\"\"}}\n\n> Source: {{url}}\n\n{{selectorHtml:.RichText|first|replace:\"href=\\\"https\\://zhida\":\"\"|markdown}}",
  "properties": [
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{selector:.UserLink-link|slice:1,2}}",
      "type": "multitext"
    },
    {
      "name": "published",
      "value": "{{selector:.Post-Row-Content .ContentItem-time}}",
      "type": "date"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "clippings, 知乎/专栏",
      "type": "multitext"
    }
  ],
  "triggers": ["https://zhuanlan.zhihu.com/p/"],
  "noteNameFormat": "{{title|replace:\" - 知乎\":\"\"}}",
  "path": "Clippings/知乎"
}
